{
  "name": "lunch-management-system",
  "version": "1.0.0",
  "description": "大学弁当予約システム - 管理者認証機能付き",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --runInBand",
    "test:api": "cross-env NODE_OPTIONS=--experimental-vm-modules jest tests/api --runInBand",
    "test:e2e": "playwright test",
    "test:watch": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage"
  },
  "keywords": [
    "lunch",
    "management",
    "system"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "body-parser": "^1.20.2",
    "express": "^4.18.2",
    "express-session": "^1.17.3"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@playwright/test": "^1.40.0",
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  }
}
